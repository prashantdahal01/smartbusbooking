# Server configuration
PORT=5001

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/smartbusbooking

# JWT secret key for token signing
JWT_SECRET=your_jwt_secret_key_here

# JWT token expiry duration
JWT_EXPIRES_IN=7d

# Password reset link expiry (minutes)
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=60

# Frontend + public base URLs (used for payment redirects)
FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5001

# Require online payment to confirm bookings
REQUIRE_ONLINE_PAYMENT=true

# eSewa ePay v2 (TEST / RC)
# Test values from eSewa documentation:
# product_code = EPAYTEST
# secret_key   = 8gBm/:&EnhH.1/q
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_FORM_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_URL=https://rc.esewa.com.np/api/epay/transaction/status/

# SMTP (required to email tickets after successful payment)
# Gmail example:
# IMPORTANT (Gmail):
# - Use an App Password (NOT your normal Gmail password).
# - Enable 2‑Step Verification, then create an App Password:
#   https://myaccount.google.com/apppasswords
# - Paste the 16‑character password (spaces are OK; the backend strips them).
# - Set either SMTP_PASSWORD or SMTP_PASS (don't set both).
SMTP_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# Optional: set a Chrome/Chromium executable path for Puppeteer in restricted environments
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
